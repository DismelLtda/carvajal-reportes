# ============================================================================
# CARVAJAL VENTAS - Variables de Entorno para Docker (PRODUCCIÓN)
# ============================================================================
# IMPORTANT: Este archivo es para uso en Rocky Linux - Docker Compose lo carga automáticamente
# NO commitar este archivo en git si contiene credenciales reales

# ============================================================================
# AMBIENTE
# ============================================================================
ENVIRONMENT=production
DEBUG=false

# ============================================================================
# BASE DE DATOS (PostgreSQL)
# ============================================================================
DATABASE_TYPE=postgresql
POSTGRES_DB=carvajal_reportes
POSTGRES_USER=carvajal_user
POSTGRES_PASSWORD=Carvajal2026Prod789#Secure
POSTGRES_PORT=5432

# URLs completas se generan automáticamente en docker-compose.yml
# DATABASE_URL=postgresql://carvajal_user:C@rvaJ@l2026__+@postgres:5432/carvajal_reportes

# ============================================================================
# API REST
# ============================================================================
API_HOST=0.0.0.0
API_PORT=10000
API_RELOAD=false

# ============================================================================
# RUTAS DE ARCHIVOS
# ============================================================================
DESCARGAS_VENTAS_DIR=/app/data/descargas_ventas
DESCARGAS_INVENTARIO_DIR=/app/data/descargas_inventario
PROCESADOS_VENTAS_DIR=/app/data/procesados_ventas
PROCESADOS_INVENTARIO_DIR=/app/data/procesados_inventario
LOGS_DIR=/app/logs

# ============================================================================
# CREDENCIALES PORTAL CENCARVAJAL
# ============================================================================
USUARIO_PORTAL=director.cadenas@dismelltda.com
CONTRASENA_PORTAL=Dismel05211921#$

# ============================================================================
# CONFIGURACIÓN DE CORREO
# ============================================================================
CORREO_REMITENTE=notificacion@dismelltda.com
PASSWORD_CORREO=muaebnciwfmoelgl
CORREO_DESTINATARIO=soporte@dismelltda.com

# ============================================================================
# TIMEZONE
# ============================================================================
TZ=America/Bogota

# ============================================================================
# SCHEDULER (Procesamiento automático de reportes)
# ============================================================================
INTERVALO_VERIFICACION=10
