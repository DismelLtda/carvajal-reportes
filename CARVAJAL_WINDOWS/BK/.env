# ============================================================================
# CARVAJAL VENTAS - Configuración Windows Server 2016 (EJEMPLO)
# ============================================================================
# Copia este archivo como: .env
# Edita los valores con tus credenciales REALES
# NO subas este archivo a Git

# ============================================================================
# CREDENCIALES PORTAL CENCARVAJAL
# ============================================================================
USUARIO_PORTAL=director.cadenas@dismelltda.com
CONTRASENA_PORTAL=Dismel05211921#$

# ============================================================================
# CONFIGURACIÓN SERVIDOR ROCKY LINUX (Docker)
# ============================================================================
# IP del servidor donde está Docker corriendo
SERVIDOR_HOST=192.168.1.254

# Puerto SSH (default: 22)
SERVIDOR_PUERTO=22

# Usuario en el servidor Rocky (creado con: adduser carvajal)
SERVIDOR_USUARIO=root

# Contraseña del usuario SSH
SERVIDOR_CONTRASEÑA=Dismel777-

# Ruta en servidor donde se guardan reportes
SERVIDOR_RUTA_DESTINO=/opt/carvajal/descargas_reportes/

# ============================================================================
# CONFIGURACIÓN DE CORREO (Notificaciones)
# ============================================================================
# Email que envía las notificaciones
CORREO_REMITENTE=notificacion@dismelltda.com

# Contraseña de la app (NO la contraseña del email)
# Para Gmail: https://support.google.com/accounts/answer/185833
PASSWORD_CORREO=muaebnciwfmoelgl

# Email donde se reciben las notificaciones
CORREO_DESTINATARIO=soporte@dismelltda.com

# ============================================================================
# DIRECTORIOS LOCALES (Windows Server)
# ============================================================================
DIRECTORIO_DESCARGAS=descargas_reportes
DIRECTORIO_LOGS=logs_sincronizacion

# Ruta completa (opcional)
# DIRECTORIO_DESCARGAS=C:\CARVAJAL_PRODUCCION\descargas_reportes
# DIRECTORIO_LOGS=C:\CARVAJAL_PRODUCCION\logs_sincronizacion
